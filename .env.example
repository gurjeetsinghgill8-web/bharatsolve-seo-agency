# BHARATSOLVE SEO AGENCY - Environment Variables
# Copy this to .env and fill in your keys

# ── AI API Keys ──
GROQ_API_KEY=gsk_your_key_here
GEMINI_API_KEY=AIza_your_key_here
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=

# ── Social Media Platform Credentials ──

# Facebook Page Posting
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Instagram Business (requires Facebook token above)
INSTAGRAM_BUSINESS_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP - Gmail recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
FROM_EMAIL=your_email@gmail.com

# OR Email via SendGrid
SENDGRID_API_KEY=

# Google Business Profile
GOOGLE_BUSINESS_TOKEN=
GOOGLE_BUSINESS_ACCOUNT=
GOOGLE_BUSINESS_LOCATION=

# Google Search Console (for real rank tracking)
GSC_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "..."}
GSC_SITE_URL=https://example.com

# Owner email (for weekly digests)
OWNER_EMAIL=

# ── WordPress (for auto-publishing content) ──
# WordPress sites are managed through the app UI.
# Application passwords are recommended: WP Admin > Users > Profile > Application Passwords
WP_DEFAULT_STATUS=publish
